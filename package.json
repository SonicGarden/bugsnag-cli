{
  "name": "@sonicgarden/bugsnag-cli",
  "version": "0.1.0",
  "description": "CLI tool for fetching error information from Bugsnag Data Access API",
  "type": "module",
  "bin": {
    "sg-bugsnag": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ test/",
    "format": "oxfmt --write src/ test/",
    "prepare": "tsdown"
  },
  "keywords": [
    "bugsnag",
    "cli",
    "error-tracking"
  ],
  "author": "SonicGarden",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
